// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ CORE MODELS ============

model Conversation {
  id          String     @id @default(cuid())
  title       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  messages    Message[]
}

model Message {
  id             String      @id @default(cuid())
  role           String
  content        String
  createdAt      DateTime    @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  agentType      String?
  agentName      String?
  confidence     Float?
  tokens         Int?
}

model Document {
  id          String   @id @default(cuid())
  filename    String
  content     String
  embedding   String?
  uploadedAt  DateTime @default(now())
}

model Citation {
  id          String   @id @default(cuid())
  messageId   String
  documentId  String
  chunkIndex  Int
  content     String
  score       Float
  createdAt   DateTime @default(now())
}
